{
    "name": "@wiz-sh/docs-workspace",
    "private": true,
    "license": "MIT",
    "workspaces": [
        "apps/*",
        "apps/docs"
    ],
    "scripts": {
        "build": "bun run --cwd apps/docs build",
        "docs": "bun run --cwd apps/docs dev",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "typecheck": "bun run --cwd apps/docs build",
        "test": "bun test",
        "cloc": "bun x --package cloc cloc apps/docs/src --include-ext=md,mdx,ts,json",
        "check": "biome check . && bun run typecheck",
        "check:fix": "biome check --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "bun-types": "^1.2.19",
        "typescript": "^5.9.2"
    },
    "packageManager": "bun@1.3.14"
}
